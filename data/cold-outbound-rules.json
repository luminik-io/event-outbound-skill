{
  "_source": "data/cold-outbound-craft.md (Encoding plan \u00a72)",
  "_about": "the cold-outbound canon-specific machine-readable rules. Layered on top of cold-email-benchmarks.json (the cross-source baseline). Channel-specific length tables, canon-only banned phrases, the leading-question regex, and the illumination-question heuristic.",
  "channel_length_rules": {
    "cold_email_first_touch": {
      "min_words": 50,
      "max_words": 100,
      "min_sent": 3,
      "max_sent": 5,
      "_source": "cold-email-archive:561-563 (\"literally four to five sentences\")"
    },
    "cold_email_followup_2": {
      "min_words": 40,
      "max_words": 90,
      "min_sent": 3,
      "max_sent": 4,
      "_source": "cold-email-archive:826-840"
    },
    "cold_email_followup_3plus": {
      "min_words": 25,
      "max_words": 60,
      "min_sent": 2,
      "max_sent": 3,
      "_source": "Pattern interrupts: lumpy mail, video, embedded graphic"
    },
    "linkedin_connection_request": {
      "max_chars": 200,
      "max_words": 35,
      "min_words": 18,
      "min_sent": 1,
      "max_sent": 2,
      "_source": "LinkedIn free-tier 200-char ceiling; canonical DM example is 32 words / 200 chars"
    },
    "linkedin_dm_post_connect": {
      "min_words": 50,
      "max_words": 120,
      "min_sent": 3,
      "max_sent": 5,
      "_source": "permission-based cadence; LinkedIn 1300-char ceiling allows more but the canon stays short"
    },
    "linkedin_day_of_nudge": {
      "min_words": 30,
      "max_words": 60,
      "min_sent": 2,
      "max_sent": 3,
      "_source": "lean-back CTA principle (cold-email-archive:614-672)"
    },
    "post_event_followup": {
      "min_words": 40,
      "max_words": 90,
      "min_sent": 2,
      "max_sent": 4,
      "_source": "Post-event \"It was great meeting at X\" pattern"
    }
  },
  "median_sentence_length_max": 12,
  "_median_sentence_length_source": "LinkedIn-CSV stats: median sentence = 6 words; 78% of sentences under 10. Soft cap at 12.",
  "strict_context_rules": {
    "apollo_merge_fields": {
      "applies_to": [
        "cold_email_first_touch",
        "cold_email_followup_2",
        "cold_email_followup_3plus",
        "linkedin_connection_request",
        "linkedin_dm_post_connect",
        "linkedin_day_of_nudge",
        "post_event_followup"
      ],
      "required_fields": [
        "{{first_name}}",
        "{{company}}"
      ]
    },
    "asset_promise_terms": [
      "attached",
      "linked",
      "1-pager",
      "one-pager",
      "worksheet",
      "checklist",
      "matrix",
      "brief",
      "recap",
      "report",
      "audit",
      "doc",
      "writeup",
      "map"
    ],
    "proof_claim_terms": [
      "using",
      "used by",
      "worked with",
      "helped",
      "from",
      "to",
      "compared to",
      "instead of",
      "cut",
      "reduced",
      "lifted",
      "increased",
      "saved",
      "shipped",
      "booked",
      "hit"
    ],
    "_source": "Cold-outbound 4T + JTBD materials. Strict mode protects the skill from inventing assets, named proof, before/after numbers, or non-Apollo placeholders when the user gave thin inputs."
  },
  "preview_line_rules": {
    "applies_to": [
      "cold_email_first_touch",
      "email_cold",
      "linkedin_dm_post_connect"
    ],
    "word_window": 18,
    "event_first_word_window": 12,
    "seller_pronouns_banned": [
      "i",
      "me",
      "my",
      "we",
      "us",
      "our",
      "ours"
    ],
    "_source": "Cold-email inbox-preview research. The subject line and first ~18 words decide whether the recipient pays attention. First-touch previews should be buyer-first, not seller-first or event-template-first."
  },
