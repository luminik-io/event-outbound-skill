    "low-pressure",
    "low pressure",
    "caught my eye",
    "caught my attention",
    "wall-to-wall",
    "wall to wall",
    "no worries",
    "no biggie",
    "hot mess",
    "needle in a haystack",
    "fire drill",
    "all hands on deck"
  ],
  "_additional_banned_phrases_source": "the corpus phrase-frequency analysis (data/cold-outbound-craft.md:380-401). Counts in 1998-post corpus: best-in-class 0, world-class 0, cutting-edge 0, industry-leading 0, robust 0, scalable 0, drive results 0, game-changer 0. the canon ridicules \"if I could 10x your revenue\" + \"would you be interested\" (4T:47-62).",
  "leading_question_pattern": {
    "regex": "\\b(if I could|wouldn'?t you|don'?t you think|would you be interested|would you be open to a (?:15|30)|would you agree)\\b",
    "flags": "i",
    "fail": true,
    "_source": "4T:55-62. The moon-and-stars + leading-question family."
  },
  "illumination_question_required": {
    "applies_to": [
      "cold_email_first_touch",
      "email_cold",
      "linkedin_dm_post_connect"
    ],
    "regex": "\\b(how|what|why)\\s+(are|do|is|can|could|would|should|did)\\s+(you|your)\\b",
    "flags": "i",
    "min_count": 1,
    "_source": "4T:84-100. Every cold-email-first-touch and post-connect DM must have at least one neutral how/what/why-are-you question."
  },
  "specific_pass_phrases": {
    "lean_back_ctas": [
      "worth a look",
      "worth a peek",
      "worth a skim",
      "worth a read",
      "worth an exchange",
      "worth a conversation",
